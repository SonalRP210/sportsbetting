{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "CPU Usage (Process vs System)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "targets": [
        { "refId": "A", "expr": "process_cpu_usage * 100", "legendFormat": "process cpu %" },
        { "refId": "B", "expr": "system_cpu_usage * 100", "legendFormat": "system cpu %" }
      ],
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "JVM Live Threads",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "targets": [{ "refId": "A", "expr": "jvm_threads_live_threads", "legendFormat": "live threads" }],
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "JVM Thread States",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "targets": [{ "refId": "A", "expr": "sum by (state) (jvm_threads_states_threads)", "legendFormat": "{{state}}" }],
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "JVM Heap Used",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "targets": [{ "refId": "A", "expr": "sum(jvm_memory_used_bytes{area=\"heap\"})", "legendFormat": "heap used" }],
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "JVM Heap Max",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "targets": [{ "refId": "A", "expr": "sum(jvm_memory_max_bytes{area=\"heap\"})", "legendFormat": "heap max" }],
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "JVM GC Pause Avg",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "targets": [{ "refId": "A", "expr": "sum(rate(jvm_gc_pause_seconds_sum[1m])) / sum(rate(jvm_gc_pause_seconds_count[1m]))", "legendFormat": "gc pause avg s" }],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "DB Pool Connections (Hikari)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "targets": [
        { "refId": "A", "expr": "hikaricp_connections_active", "legendFormat": "active" },
        { "refId": "B", "expr": "hikaricp_connections_idle", "legendFormat": "idle" },
        { "refId": "C", "expr": "hikaricp_connections_pending", "legendFormat": "pending" }
      ],
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "DB Pool Limits (Hikari)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "targets": [
        { "refId": "A", "expr": "hikaricp_connections_min", "legendFormat": "min" },
        { "refId": "B", "expr": "hikaricp_connections_max", "legendFormat": "max" }
      ],
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "JDBC Connections",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "targets": [
        { "refId": "A", "expr": "jdbc_connections_active", "legendFormat": "active" },
        { "refId": "B", "expr": "jdbc_connections_idle", "legendFormat": "idle" },
        { "refId": "C", "expr": "jdbc_connections_max", "legendFormat": "max" }
      ],
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Executor Threads and Queue",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "targets": [
        { "refId": "A", "expr": "executor_active_threads", "legendFormat": "active threads" },
        { "refId": "B", "expr": "executor_pool_size_threads", "legendFormat": "pool size" },
        { "refId": "C", "expr": "executor_queued_tasks", "legendFormat": "queued tasks" }
      ],
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] }
    }
  ],
  "refresh": "5s",
  "schemaVersion": 39,
  "tags": ["loadtest", "k6", "sportsbetting", "runtime"],
  "templating": { "list": [] },
  "time": { "from": "now-30m", "to": "now" },
  "timezone": "",
  "title": "Load Test - Runtime Health",
  "uid": "sportsbetting-loadtest-runtime",
  "version": 1,
  "weekStart": ""
}
