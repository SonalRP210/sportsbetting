  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "k6 Request Rate",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "targets": [{ "refId": "A", "expr": "sum(rate(k6_http_reqs_total[2m]))", "legendFormat": "k6 req/s" }],
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "k6 Failed Request Rate",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "targets": [{ "refId": "A", "expr": "avg(last_over_time(k6_http_req_failed_rate[2m])) * 100", "legendFormat": "failed %" }],
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "k6 HTTP P95 Duration",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "targets": [{ "refId": "A", "expr": "avg(last_over_time(k6_http_req_duration_p95[2m])) * 1000", "legendFormat": "p95 ms" }],
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "App HTTP Throughput",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "targets": [{ "refId": "A", "expr": "sum(rate(http_server_requests_seconds_count[1m]))", "legendFormat": "app req/s" }],
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "App HTTP Avg Latency",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "targets": [{ "refId": "A", "expr": "sum(rate(http_server_requests_seconds_sum[1m])) / sum(rate(http_server_requests_seconds_count[1m])) * 1000", "legendFormat": "avg ms" }],
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Total Bets Exposure",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "targets": [{ "refId": "A", "expr": "bets_exposure", "legendFormat": "exposure" }],
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Rate Limit Test - 429 Rate",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "targets": [{ "refId": "A", "expr": "avg(k6_rate_limit_errors_rate{test=\"rate_limit\"}) * 100", "legendFormat": "rate_limit 429 %" }],
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Rate Limit Test - Duration P95",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
