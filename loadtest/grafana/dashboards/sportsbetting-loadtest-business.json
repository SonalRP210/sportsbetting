      "id": 1,
      "type": "timeseries",
      "title": "k6 Request Rate",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "targets": [{ "refId": "A", "expr": "sum(rate(k6_http_reqs_total[2m]))", "legendFormat": "k6 req/s" }],
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "k6 Failed Request Rate",
