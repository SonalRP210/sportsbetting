      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 24 },
      "targets": [{ "refId": "A", "expr": "avg(k6_bet_placement_duration_ms_p95{test=\"bet_placement\"})", "legendFormat": "bet placement p95" }],
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Odds Feed - Processed Events",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 24 },
